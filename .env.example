# App
PORT=3000
NODE_ENV=development

# Admin security (leave empty to disable admin lock)
ADMIN_TOKEN=

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=anime_avatar_expo
MYSQL_CONNECTION_LIMIT=10

# Upload storage
UPLOAD_DIR=uploads/images
MAX_FILE_SIZE_MB=20

# Scraper
SCRAPER_HEADLESS=true
SCRAPER_TIMEOUT_MS=45000
SCRAPER_MAX_SCROLL=6
PLAYWRIGHT_STORAGE_STATE=